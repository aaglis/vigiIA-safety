{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vigia-safety.local/contracts/events/edge-heartbeat.v1.schema.json",
  "title": "edge-heartbeat.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["client_id", "organization_id", "sent_at", "status"],
  "properties": {
    "client_id": { "type": "string", "minLength": 1 },
    "organization_id": { "type": "string", "minLength": 1 },
    "sent_at": { "type": "string", "format": "date-time" },
    "site_id": { "type": ["string", "null"] },
    "worker_id": { "type": ["string", "null"] },
    "version": { "type": ["string", "null"] },
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": {
        "state": { "type": "string", "enum": ["ok", "degraded", "offline"] },
        "cpu_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "memory_percent": { "type": "number", "minimum": 0, "maximum": 100 },
        "queue_depth": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
