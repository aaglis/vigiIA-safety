{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vigia-safety.local/contracts/events/detection-event.v1.schema.json",
  "title": "detection-event.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "organization_id", "timestamp", "camera_id", "zone_id", "event_type", "confidence"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "organization_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "camera_id": { "type": "string", "minLength": 1 },
    "zone_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "model_version": { "type": ["string", "null"] },
    "worker_id": { "type": ["string", "null"] },
    "site_id": { "type": ["string", "null"] },
    "severity": { "type": ["string", "null"] },
    "evidence": { "type": ["object", "null"], "additionalProperties": true }
  }
}
