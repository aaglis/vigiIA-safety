{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vigia-safety.local/contracts/events/notification-requested.v1.schema.json",
  "title": "notification-requested.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["notification_id", "incident_id", "organization_id", "created_at", "channels", "recipients", "template_key"],
  "properties": {
    "notification_id": { "type": "string", "minLength": 1 },
    "incident_id": { "type": "string", "minLength": 1 },
    "organization_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "template_key": { "type": "string", "minLength": 1 },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["dashboard", "email", "whatsapp"] }
    },
    "recipients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["recipient_id", "recipient_type"],
        "properties": {
          "recipient_id": { "type": "string", "minLength": 1 },
          "recipient_type": { "type": "string", "enum": ["supervisor", "worker_external", "system"] },
          "email": { "type": "string", "format": "email" },
          "channel_preferences": {
            "type": "array",
            "items": { "type": "string", "enum": ["dashboard", "email", "whatsapp"] }
          }
        }
      }
    },
    "deduplication_key": { "type": "string" },
    "cooldown_until": { "type": "string", "format": "date-time" },
    "reason": { "type": "string" }
  }
}
