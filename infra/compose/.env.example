# Config de dev do stack local (dev-only, sem segredos reais).
# Uso: rode o compose a partir DESTA pasta (infra/compose) para o .env ser lido:
#   cd infra/compose
#   cp .env.example .env              # uma vez; ajuste se quiser
#   docker compose up                 # base (sem visao computacional)
#   docker compose --profile cv up    # base + worker de CV
#
# COMPOSE_FILE abaixo faz o `docker compose` pegar o arquivo certo sem precisar de -f.
# (Sem o .env, use: docker compose -f docker-compose.dev.yml up)
COMPOSE_FILE=docker-compose.dev.yml

# Todos os valores abaixo já têm default no compose — o .env só serve para ajustar.

# --- Visão computacional (worker, profile cv) ---
# Modelo YOLO. yolov8n.pt (COCO) já detecta 'person' -> cobre intrusão em zona restrita.
# Para EPI (capacete) aponte para um modelo com classe helmet/head em apps/edge-worker/models/,
# ex.: CV_MODEL_PATH=/models/ppe.pt
CV_MODEL_PATH=yolov8n.pt
CV_CONFIDENCE_THRESHOLD=0.4
# Processa 1 a cada N frames do vídeo (maior = mais leve/rápido).
EDGE_VIDEO_FRAME_STRIDE=15
# true = processa a fonte uma vez e para; false = fica vivo (como uma câmera 24/7).
EDGE_RUN_ONCE=true
# Intervalo entre ciclos no modo contínuo (s).
EDGE_POLL_INTERVAL_SECONDS=30
# Não repete o mesmo incidente (mesma câmera+zona+tipo) dentro da janela (s). 0 desliga.
EDGE_DETECTION_COOLDOWN_SECONDS=60
# Backoff de reconexão para stream ao vivo (RTSP) que cai.
EDGE_RECONNECT_BACKOFF_SECONDS=2
EDGE_RECONNECT_MAX_BACKOFF_SECONDS=30

# Vídeo que faz o papel da câmera demo em localhost.
# Coloque o arquivo em apps/edge-worker/assets/ (montado em /assets no container).
DEMO_CAMERA_STREAM=/assets/sample-ppe.mp4
