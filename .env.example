# Root defaults for local development (dev-only values; never use in production)

APP_NAME=VigIA API
APP_ENV=dev
API_V1_PREFIX=/api/v1
REPOSITORY_BACKEND=memory
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=5173

POSTGRES_DB=vigia
POSTGRES_USER=vigia
POSTGRES_PASSWORD=dev-only-change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=15432
POSTGRES_URL=postgresql+psycopg://vigia:dev-only-change-me@postgres:5432/vigia
DATABASE_URL=postgresql+psycopg://vigia:dev-only-change-me@postgres:5432/vigia

REDIS_URL=redis://redis:6379/0
RATE_LIMIT_BACKEND=auto
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=16379

MINIO_ROOT_USER=vigia
MINIO_ROOT_PASSWORD=dev-only-change-me
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_EVIDENCE=vigia-evidence-private
EVIDENCE_BUCKET_NAME=vigia-evidence-private
EVIDENCE_PRESIGNED_URL_TTL_SECONDS=300
S3_REGION=us-east-1
S3_ENDPOINT_URL=http://minio:9000
MINIO_ACCESS_KEY=dev-only
MINIO_SECRET_KEY=dev-only

SMTP_HOST=smtp.dev.local
SMTP_PORT=1025
SMTP_USER=dev-only
SMTP_PASSWORD=dev-only
SMTP_FROM=alerts@vigia.local
SMTP_URL=smtp://dev-only:dev-only@smtp.dev.local:1025

PLATFORM_API_KEY=dev-only
PLATFORM_WEBHOOK_SECRET=dev-only
EDGE_WORKER_API_KEY=dev-only
EDGE_WORKER_CLIENT_ID=dev-client-id
EDGE_WORKER_SECRET=dev-only

WEB_API_BASE_URL=http://localhost:8000/api/v1
